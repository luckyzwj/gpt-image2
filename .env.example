# ====================================
# Database Configuration
# ====================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database?sslmode=require
DATABASE_URL="postgresql://username:password@host/database?sslmode=require"

# ====================================
# Authentication (Better Auth)
# ====================================
# Secret key for Better Auth (must be at least 32 characters in production)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-super-secret-key-at-least-32-characters-long-for-production"

# The URL where your app is hosted
BETTER_AUTH_URL="http://localhost:3000"

# ====================================
# Google OAuth (Optional)
# ====================================
# Get these from: https://console.cloud.google.com/
# Guide: https://authjs.dev/getting-started/providers/google
# The Google button appears automatically when both values are set.
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ====================================
# AI Providers (Optional)
# ====================================
# Volcano Engine (火山引擎) - Doubao (豆包) API
# Get your API key from: https://console.volcengine.com/ark
# One API key for all features: chat, image generation, video generation
VOLCANO_ENGINE_API_KEY="your-volcano-engine-api-key"
VOLCANO_ENGINE_API_URL="https://ark.cn-beijing.volces.com/api/v3"
OPENAI_API_KEY="your-openai-api-key"
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_RESPONSES_MODEL="gpt-5.4"
OPENAI_IMAGE_MODEL="gpt-image-2"

# ====================================
# Email Service (Required for email features)
# ====================================
# Resend API for transactional emails
# Get your API key from: https://resend.com
RESEND_API_KEY="re_your_api_key"

# Email Configuration - Choose one of the following options:
#
# Set a complete from email address (recommended, highest priority)
RESEND_FROM_EMAIL="Your App <noreply@yourdomain.com>"

# Optional: Resend Audience ID for newsletter/marketing
RESEND_AUDIENCE_ID="your-resend-audience-id"

# ====================================
# Analytics & Monitoring (Optional)
# ====================================
# Posthog Analytics
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=""

# Google Analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=""

# Microsoft Clarity
NEXT_PUBLIC_CLARITY_PROJECT_ID=""

# Analytics Feature Flags（可选）
NEXT_PUBLIC_ANALYTICS_ENABLE_IN_DEVELOPMENT=""

# ====================================
# Application Settings
# ====================================
# Public app URL (update in production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Basic auth for Sistine cron callbacks
CRON_JOBS_USERNAME="your_username"
CRON_JOBS_PASSWORD="your_password"
# Optional bearer token if you prefer header-based auth
CRON_SECRET="set-a-strong-cron-secret"

# Node environment
NODE_ENV="development"

# ====================================
# Payments (Creem)
# ====================================
# Get your API key and configure webhook endpoint in Creem dashboard
CREEM_API_KEY="your-creem-api-key"
CREEM_WEBHOOK_SECRET="whsec_..."
# Optional overrides (use if your Creem test environment uses a different domain/path)
CREEM_API_BASE="https://api.creem.io"
# CREEM_CHECKOUT_PATH="/v1/checkout/sessions"
# Set to true to simulate checkout redirect (no external call). In this mode, checkout will redirect to /dashboard?success=1
# CREEM_SIMULATE="false"
# Webhook endpoint to configure in Creem dashboard (for reference):
#   https://your-domain.com/api/payments/creem/webhook

# ====================================
# Feature Flags (Optional)
# ====================================
# Enable/disable features
NEXT_PUBLIC_ENABLE_CHAT="false"
NEXT_PUBLIC_MAINTENANCE_MODE="false"

# ====================================
# Studio Gateway (reverse-proxy to aEboli on Cloudflare)
# ====================================
# aEboli's Cloudflare Worker hostname — where /studio/* is proxied to.
# Example: https://gpt-image2-studio-api.example.workers.dev
STUDIO_GATEWAY_ORIGIN=""

# Shared HMAC secret. Must match aEboli's `wrangler secret put STUDIO_GATEWAY_SECRET`.
# Minimum 32 chars. Generate with: openssl rand -base64 48
STUDIO_GATEWAY_SECRET=""

# ====================================
# Studio: BYO Key encryption (Required when users save provider keys)
# ====================================
# AES-256-GCM master secret used by lib/studio/providers/openai/crypto.ts to
# encrypt user-supplied OpenAI keys at rest. Accepts base64 (32 bytes),
# hex (64 chars), or any string (will be SHA-256 hashed to 32 bytes).
# Generate with: openssl rand -base64 32
# If unset, falls back to STUDIO_BYO_KEY_SECRET, then BETTER_AUTH_SECRET.
BYO_KEY_MASTER_KEY=""

# ====================================
# Storage backend selector
# ====================================
# Which storage adapter to use for studio assets:
#   fs        — local filesystem (dev only; reads via /api/storage/[...path])
#   r2        — Cloudflare R2 / any S3-compatible bucket (recommended for prod)
#   data-url  — embed as base64 in DB (smoke tests only; default fallback)
# Leave empty to auto-detect R2 from STORAGE_* vars below, else use data-url.
STORAGE_BACKEND=""

# Required when STORAGE_BACKEND=fs
# Absolute path that holds studio/<kind>/<userId>/<ts>_<rand>.<ext> files.
STORAGE_FS_ROOT=""

# Required when STORAGE_BACKEND=r2 (or to auto-select R2 with STORAGE_BACKEND="")
STORAGE_REGION="your-region"
STORAGE_BUCKET_NAME="your-bucket"
STORAGE_ACCESS_KEY_ID="your-access-key"
STORAGE_SECRET_ACCESS_KEY="your-secret-key"
STORAGE_ENDPOINT="https://example.r2.cloudflarestorage.com"
STORAGE_PUBLIC_URL="https://example.com"
